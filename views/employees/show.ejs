<%- include('../partials/header') %>

<!-- Hero header -->
<div class="rounded-3xl bg-gradient-to-br from-brand-600 via-brand-700 to-brand-900 text-white p-8 shadow-soft relative overflow-hidden mb-8">
  <div class="absolute -top-16 -right-10 h-56 w-56 rounded-full bg-white/10 blur-2xl"></div>
  <div class="relative flex flex-wrap items-center gap-5">
    <span class="grid place-items-center h-16 w-16 rounded-2xl bg-white/15 backdrop-blur text-2xl font-extrabold uppercase">
      <%= employee.name.trim().charAt(0) %>
    </span>
    <div>
      <h1 class="text-2xl font-extrabold leading-tight">Hello, <%= employee.name.split(' ')[0] %> 👋</h1>
      <p class="text-brand-100/90 text-sm mt-1">
        <span class="capitalize"><%= employee.role %></span>
        <% if (employee.company) { %> · <%= employee.company %><% } %>
      </p>
    </div>
    <div class="ml-auto flex gap-2">
      <form action="/attendance/check-in?_method=POST" method="POST">
        <button class="rounded-xl bg-white text-brand-700 px-4 py-2.5 text-sm font-semibold hover:bg-brand-50 active:scale-[.98] transition shadow">Check In</button>
      </form>
      <form action="/attendance/check-out?_method=POST" method="POST">
        <button class="rounded-xl bg-white/15 backdrop-blur text-white px-4 py-2.5 text-sm font-semibold hover:bg-white/25 active:scale-[.98] transition ring-1 ring-white/30">Check Out</button>
      </form>
    </div>
  </div>
</div>

<!-- Monthly attendance report -->
<div class="flex items-center justify-between mb-3">
  <h2 class="text-base font-bold text-slate-900">This month's attendance</h2>
  <span class="text-xs text-slate-400"><%= summary.elapsed %> days elapsed</span>
</div>
<div class="grid grid-cols-2 sm:grid-cols-4 gap-5 mb-8">
  <div class="bg-white rounded-2xl border border-slate-100 shadow-soft p-5">
    <p class="text-sm font-medium text-slate-500">Present</p>
    <p class="mt-2 text-3xl font-extrabold text-emerald-600"><%= summary.present %></p>
  </div>
  <div class="bg-white rounded-2xl border border-slate-100 shadow-soft p-5">
    <p class="text-sm font-medium text-slate-500">On leave</p>
    <p class="mt-2 text-3xl font-extrabold text-amber-600"><%= summary.leave %></p>
  </div>
  <div class="bg-white rounded-2xl border border-slate-100 shadow-soft p-5">
    <p class="text-sm font-medium text-slate-500">Absent</p>
    <p class="mt-2 text-3xl font-extrabold text-red-500"><%= summary.absent %></p>
  </div>
  <div class="bg-white rounded-2xl border border-slate-100 shadow-soft p-5">
    <p class="text-sm font-medium text-slate-500">Leave requests</p>
    <p class="mt-2 text-3xl font-extrabold text-slate-900"><%= leaves.length %></p>
  </div>
</div>

<div class="grid lg:grid-cols-3 gap-6 items-start">
  <!-- Profile card -->
  <div class="lg:col-span-1 space-y-6">
   <div class="bg-white rounded-2xl border border-slate-100 shadow-soft p-6">
    <div class="flex items-center justify-between mb-5">
      <h2 class="text-base font-bold text-slate-900">My Profile</h2>
      <div class="flex items-center gap-3">
        <a href="/change-password" class="text-slate-500 text-sm font-semibold hover:underline">Password</a>
        <a href="/employees/<%= employee.id %>/edit" class="text-brand-600 text-sm font-semibold hover:underline">Edit</a>
      </div>
    </div>
    <dl class="space-y-4 text-sm">
      <div><dt class="text-xs uppercase tracking-wide text-slate-400 font-semibold">Login ID</dt><dd class="font-medium text-slate-800 mt-0.5"><%= employee.login_code || '—' %></dd></div>
      <div><dt class="text-xs uppercase tracking-wide text-slate-400 font-semibold">Name</dt><dd class="font-medium text-slate-800 mt-0.5"><%= employee.name %></dd></div>
      <div><dt class="text-xs uppercase tracking-wide text-slate-400 font-semibold">Email</dt><dd class="font-medium text-slate-800 mt-0.5"><%= employee.email %></dd></div>
      <div><dt class="text-xs uppercase tracking-wide text-slate-400 font-semibold">Company</dt><dd class="font-medium text-slate-800 mt-0.5"><%= employee.company || '—' %></dd></div>
      <div><dt class="text-xs uppercase tracking-wide text-slate-400 font-semibold">Role</dt><dd class="font-medium text-slate-800 mt-0.5 capitalize"><%= employee.role %></dd></div>
      <div><dt class="text-xs uppercase tracking-wide text-slate-400 font-semibold">Phone</dt><dd class="font-medium text-slate-800 mt-0.5"><%= employee.phone || '—' %></dd></div>
      <div><dt class="text-xs uppercase tracking-wide text-slate-400 font-semibold">Address</dt><dd class="font-medium text-slate-800 mt-0.5"><%= employee.address || '—' %></dd></div>
    </dl>
   </div>

   <!-- About card -->
   <div class="bg-white rounded-2xl border border-slate-100 shadow-soft p-6">
    <h2 class="text-base font-bold text-slate-900 mb-4">About</h2>
    <p class="text-sm text-slate-600 whitespace-pre-line"><%= employee.about || 'Tell your team about yourself — click Edit above.' %></p>
    <div class="mt-4 space-y-3 text-sm">
      <div><dt class="text-xs uppercase tracking-wide text-slate-400 font-semibold">Skills</dt><dd class="text-slate-700 mt-0.5"><%= employee.skills || '—' %></dd></div>
      <div><dt class="text-xs uppercase tracking-wide text-slate-400 font-semibold">Certifications</dt><dd class="text-slate-700 mt-0.5"><%= employee.certifications || '—' %></dd></div>
      <div><dt class="text-xs uppercase tracking-wide text-slate-400 font-semibold">Resume</dt><dd class="mt-0.5"><% if (employee.resume_url) { %><a href="<%= employee.resume_url %>" target="_blank" class="text-brand-600 font-semibold hover:underline">Open resume ↗</a><% } else { %><span class="text-slate-400">—</span><% } %></dd></div>
    </div>
   </div>
  </div>

  <!-- Attendance + Leaves -->
  <div class="lg:col-span-2 space-y-6">
    <div class="bg-white rounded-2xl border border-slate-100 shadow-soft p-6">
      <h2 class="text-base font-bold text-slate-900 mb-4">Recent Attendance</h2>
      <div class="overflow-x-auto">
        <table class="w-full text-sm">
          <thead>
            <tr class="text-left text-xs uppercase tracking-wide text-slate-400 border-b border-slate-100">
              <th class="py-2.5 font-semibold">Date</th><th class="font-semibold">Check In</th><th class="font-semibold">Check Out</th>
            </tr>
          </thead>
          <tbody class="divide-y divide-slate-50">
            <% if (!attendance.length) { %>
              <tr><td colspan="3" class="py-6 text-center text-slate-400">No attendance records yet.</td></tr>
            <% } %>
            <% attendance.forEach(a => { %>
              <tr class="hover:bg-slate-50/60 transition">
                <td class="py-3 font-medium text-slate-700"><%= a.work_date.toISOString ? a.work_date.toISOString().slice(0,10) : a.work_date %></td>
                <td class="text-slate-600"><%= a.check_in ? new Date(a.check_in).toLocaleTimeString() : '—' %></td>
                <td class="text-slate-600"><%= a.check_out ? new Date(a.check_out).toLocaleTimeString() : '—' %></td>
              </tr>
            <% }) %>
          </tbody>
        </table>
      </div>
    </div>

    <div class="bg-white rounded-2xl border border-slate-100 shadow-soft p-6">
      <div class="flex items-center justify-between mb-4">
        <h2 class="text-base font-bold text-slate-900">My Leave Requests</h2>
        <% if (currentUser.role !== 'admin') { %>
          <a href="/leaves/new" class="rounded-lg bg-brand-600 text-white px-3.5 py-2 text-sm font-semibold hover:bg-brand-700 transition">+ Apply Leave</a>
        <% } %>
      </div>
      <div class="overflow-x-auto">
        <table class="w-full text-sm">
          <thead>
            <tr class="text-left text-xs uppercase tracking-wide text-slate-400 border-b border-slate-100">
              <th class="py-2.5 font-semibold">From</th><th class="font-semibold">To</th><th class="font-semibold">Type</th><th class="font-semibold">Reason</th><th class="font-semibold">Status</th>
            </tr>
          </thead>
          <tbody class="divide-y divide-slate-50">
            <% if (!leaves.length) { %>
              <tr><td colspan="5" class="py-6 text-center text-slate-400">No leave requests yet.</td></tr>
            <% } %>
            <% leaves.forEach(l => { %>
              <tr class="hover:bg-slate-50/60 transition">
                <td class="py-3 font-medium text-slate-700"><%= l.start_date.toISOString ? l.start_date.toISOString().slice(0,10) : l.start_date %></td>
                <td class="text-slate-600"><%= l.end_date.toISOString ? l.end_date.toISOString().slice(0,10) : l.end_date %></td>
                <td class="text-slate-600"><span class="px-2 py-0.5 rounded-full text-xs font-semibold <%= l.leave_type === 'sick' ? 'bg-rose-50 text-rose-700' : 'bg-sky-50 text-sky-700' %>"><%= l.leave_type === 'sick' ? 'Sick' : 'Paid' %></span></td>
                <td class="text-slate-600 max-w-[12rem] truncate"><%= l.reason || '—' %></td>
                <td>
                  <span class="inline-flex items-center gap-1.5 px-2.5 py-1 rounded-full text-xs font-semibold
                    <%= l.status === 'approved' ? 'bg-emerald-50 text-emerald-700' : l.status === 'rejected' ? 'bg-red-50 text-red-700' : 'bg-amber-50 text-amber-700' %>">
                    <span class="h-1.5 w-1.5 rounded-full <%= l.status === 'approved' ? 'bg-emerald-500' : l.status === 'rejected' ? 'bg-red-500' : 'bg-amber-500' %>"></span>
                    <%= l.status %>
                  </span>
                </td>
              </tr>
            <% }) %>
          </tbody>
        </table>
      </div>
    </div>
  </div>
</div>

<%- include('../partials/footer') %>

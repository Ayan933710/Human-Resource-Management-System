<%- include('../partials/header') %>

<a href="/employees" class="inline-flex items-center gap-1.5 text-sm font-semibold text-slate-500 hover:text-brand-700 mb-4">← Back to employees</a>

<!-- Header -->
<div class="rounded-3xl bg-gradient-to-br from-brand-600 via-brand-700 to-brand-900 text-white p-8 shadow-soft relative overflow-hidden mb-8">
  <div class="absolute -top-16 -right-10 h-56 w-56 rounded-full bg-white/10 blur-2xl"></div>
  <div class="relative flex flex-wrap items-center gap-5">
    <span class="grid place-items-center h-16 w-16 rounded-2xl bg-white/15 backdrop-blur text-2xl font-extrabold uppercase"><%= employee.name.trim().charAt(0) %></span>
    <div>
      <h1 class="text-2xl font-extrabold leading-tight"><%= employee.name %></h1>
      <p class="text-brand-100/90 text-sm mt-1"><span class="capitalize"><%= employee.role %></span> · <%= employee.company %></p>
    </div>
    <div class="ml-auto flex flex-wrap gap-2">
      <a href="/employees/<%= employee.id %>/edit" class="rounded-xl bg-white text-brand-700 px-4 py-2.5 text-sm font-semibold hover:bg-brand-50 transition shadow">Edit</a>
      <a href="/salary" class="rounded-xl bg-white/15 backdrop-blur text-white px-4 py-2.5 text-sm font-semibold hover:bg-white/25 transition ring-1 ring-white/30">Salary</a>
      <form action="/employees/<%= employee.id %>?_method=DELETE" method="POST"
            onsubmit="return confirm('Remove <%= employee.name %> from the company? This deletes all their records.');">
        <button class="rounded-xl bg-red-500/90 text-white px-4 py-2.5 text-sm font-semibold hover:bg-red-600 transition shadow">Remove</button>
      </form>
    </div>
  </div>
</div>

<!-- Monthly summary -->
<div class="grid sm:grid-cols-4 gap-5 mb-8">
  <div class="bg-white rounded-2xl border border-slate-100 shadow-soft p-5"><p class="text-sm font-medium text-slate-500">Present (this month)</p><p class="mt-2 text-3xl font-extrabold text-emerald-600"><%= summary.present %></p></div>
  <div class="bg-white rounded-2xl border border-slate-100 shadow-soft p-5"><p class="text-sm font-medium text-slate-500">On leave</p><p class="mt-2 text-3xl font-extrabold text-amber-600"><%= summary.leave %></p></div>
  <div class="bg-white rounded-2xl border border-slate-100 shadow-soft p-5"><p class="text-sm font-medium text-slate-500">Absent</p><p class="mt-2 text-3xl font-extrabold text-red-500"><%= summary.absent %></p></div>
  <div class="bg-white rounded-2xl border border-slate-100 shadow-soft p-5"><p class="text-sm font-medium text-slate-500">Base salary</p><p class="mt-2 text-3xl font-extrabold text-slate-900">₹<%= Number(employee.base_salary).toLocaleString() %></p></div>
</div>

<div class="grid lg:grid-cols-3 gap-6 items-start">
  <!-- Details (read-only) -->
  <div class="lg:col-span-1 space-y-6">
    <div class="bg-white rounded-2xl border border-slate-100 shadow-soft p-6">
      <h2 class="text-base font-bold text-slate-900 mb-5">Details</h2>
      <dl class="space-y-4 text-sm">
        <div><dt class="text-xs uppercase tracking-wide text-slate-400 font-semibold">Login ID</dt><dd class="font-medium text-slate-800 mt-0.5"><%= employee.login_code || '—' %></dd></div>
        <div><dt class="text-xs uppercase tracking-wide text-slate-400 font-semibold">Email</dt><dd class="font-medium text-slate-800 mt-0.5"><%= employee.email %></dd></div>
        <div><dt class="text-xs uppercase tracking-wide text-slate-400 font-semibold">Role</dt><dd class="font-medium text-slate-800 mt-0.5 capitalize"><%= employee.role %></dd></div>
        <div><dt class="text-xs uppercase tracking-wide text-slate-400 font-semibold">Year joined</dt><dd class="font-medium text-slate-800 mt-0.5"><%= employee.year_joined || '—' %></dd></div>
        <div><dt class="text-xs uppercase tracking-wide text-slate-400 font-semibold">Phone</dt><dd class="font-medium text-slate-800 mt-0.5"><%= employee.phone || '—' %></dd></div>
        <div><dt class="text-xs uppercase tracking-wide text-slate-400 font-semibold">Address</dt><dd class="font-medium text-slate-800 mt-0.5"><%= employee.address || '—' %></dd></div>
        <div><dt class="text-xs uppercase tracking-wide text-slate-400 font-semibold">Verified</dt><dd class="font-medium mt-0.5 <%= employee.is_verified ? 'text-emerald-600' : 'text-red-500' %>"><%= employee.is_verified ? 'Yes' : 'Pending' %></dd></div>
      </dl>
    </div>

    <div class="bg-white rounded-2xl border border-slate-100 shadow-soft p-6">
      <h2 class="text-base font-bold text-slate-900 mb-4">About</h2>
      <p class="text-sm text-slate-600 whitespace-pre-line"><%= employee.about || 'No description added.' %></p>
      <div class="mt-4 space-y-3 text-sm">
        <div><dt class="text-xs uppercase tracking-wide text-slate-400 font-semibold">Skills</dt><dd class="text-slate-700 mt-0.5"><%= employee.skills || '—' %></dd></div>
        <div><dt class="text-xs uppercase tracking-wide text-slate-400 font-semibold">Certifications</dt><dd class="text-slate-700 mt-0.5"><%= employee.certifications || '—' %></dd></div>
        <div><dt class="text-xs uppercase tracking-wide text-slate-400 font-semibold">Resume</dt><dd class="mt-0.5"><% if (employee.resume_url) { %><a href="<%= employee.resume_url %>" target="_blank" class="text-brand-600 font-semibold hover:underline">Open resume ↗</a><% } else { %><span class="text-slate-400">—</span><% } %></dd></div>
      </div>
    </div>
  </div>

  <!-- Attendance + Leaves -->
  <div class="lg:col-span-2 space-y-6">
    <div class="bg-white rounded-2xl border border-slate-100 shadow-soft p-6">
      <h2 class="text-base font-bold text-slate-900 mb-4">Recent Attendance</h2>
      <div class="overflow-x-auto">
        <table class="w-full text-sm">
          <thead><tr class="text-left text-xs uppercase tracking-wide text-slate-400 border-b border-slate-100">
            <th class="py-2.5 font-semibold">Date</th><th class="font-semibold">Check In</th><th class="font-semibold">Check Out</th><th class="font-semibold">Status</th>
          </tr></thead>
          <tbody class="divide-y divide-slate-50">
            <% if (!attendance.length) { %><tr><td colspan="4" class="py-6 text-center text-slate-400">No records.</td></tr><% } %>
            <% attendance.forEach(a => { %>
              <tr class="hover:bg-slate-50/60 transition">
                <td class="py-3 font-medium text-slate-700"><%= a.work_date.toISOString ? a.work_date.toISOString().slice(0,10) : a.work_date %></td>
                <td class="text-slate-600"><%= a.check_in ? new Date(a.check_in).toLocaleTimeString() : '—' %></td>
                <td class="text-slate-600"><%= a.check_out ? new Date(a.check_out).toLocaleTimeString() : '—' %></td>
                <td><span class="px-2.5 py-1 rounded-full text-xs font-semibold capitalize <%= a.status === 'approved' ? 'bg-emerald-50 text-emerald-700' : a.status === 'rejected' ? 'bg-red-50 text-red-700' : 'bg-amber-50 text-amber-700' %>"><%= a.status %></span></td>
              </tr>
            <% }) %>
          </tbody>
        </table>
      </div>
    </div>

    <div class="bg-white rounded-2xl border border-slate-100 shadow-soft p-6">
      <h2 class="text-base font-bold text-slate-900 mb-4">Leave Requests</h2>
      <div class="overflow-x-auto">
        <table class="w-full text-sm">
          <thead><tr class="text-left text-xs uppercase tracking-wide text-slate-400 border-b border-slate-100">
            <th class="py-2.5 font-semibold">From</th><th class="font-semibold">To</th><th class="font-semibold">Type</th><th class="font-semibold">Status</th>
          </tr></thead>
          <tbody class="divide-y divide-slate-50">
            <% if (!leaves.length) { %><tr><td colspan="4" class="py-6 text-center text-slate-400">No leave requests.</td></tr><% } %>
            <% leaves.forEach(l => { %>
              <tr class="hover:bg-slate-50/60 transition">
                <td class="py-3 font-medium text-slate-700"><%= l.start_date.toISOString ? l.start_date.toISOString().slice(0,10) : l.start_date %></td>
                <td class="text-slate-600"><%= l.end_date.toISOString ? l.end_date.toISOString().slice(0,10) : l.end_date %></td>
                <td class="text-slate-600 capitalize"><%= l.leave_type === 'sick' ? 'Sick' : 'Paid' %> time off</td>
                <td><span class="px-2.5 py-1 rounded-full text-xs font-semibold capitalize <%= l.status === 'approved' ? 'bg-emerald-50 text-emerald-700' : l.status === 'rejected' ? 'bg-red-50 text-red-700' : 'bg-amber-50 text-amber-700' %>"><%= l.status %></span></td>
              </tr>
            <% }) %>
          </tbody>
        </table>
      </div>
    </div>
  </div>
</div>

<%- include('../partials/footer') %>

<%- include('partials/header') %>

<div class="grid lg:grid-cols-2 gap-8 items-stretch max-w-5xl mx-auto mt-4">

  <!-- Brand / marketing panel -->
  <div class="hidden lg:flex flex-col justify-between rounded-3xl p-10 text-white bg-gradient-to-br from-brand-600 via-brand-700 to-brand-900 shadow-soft relative overflow-hidden">
    <div class="absolute -top-20 -right-20 h-64 w-64 rounded-full bg-white/10 blur-2xl"></div>
    <div class="absolute -bottom-24 -left-10 h-64 w-64 rounded-full bg-brand-400/20 blur-2xl"></div>
    <div class="relative">
      <span class="grid place-items-center h-12 w-12 rounded-2xl bg-white/15 backdrop-blur text-2xl font-extrabold">H</span>
      <h2 class="mt-8 text-3xl font-extrabold leading-tight">Welcome back to<br/>your people platform.</h2>
      <p class="mt-4 text-brand-100/90 leading-relaxed">Manage attendance, leaves and your team — all in one clean workspace built for modern HR.</p>
    </div>
    <ul class="relative space-y-3 text-sm text-brand-50/90">
      <li class="flex items-center gap-3"><span class="h-1.5 w-1.5 rounded-full bg-white"></span> Role-based access for HR &amp; employees</li>
      <li class="flex items-center gap-3"><span class="h-1.5 w-1.5 rounded-full bg-white"></span> One-click check-in / check-out</li>
      <li class="flex items-center gap-3"><span class="h-1.5 w-1.5 rounded-full bg-white"></span> Streamlined leave approvals</li>
    </ul>
  </div>

  <!-- Form card -->
  <div class="bg-white rounded-3xl shadow-soft border border-slate-100 p-8 sm:p-10 flex flex-col justify-center">
    <div class="mb-8">
      <h1 class="text-2xl font-extrabold text-slate-900">Sign in</h1>
      <p class="text-sm text-slate-500 mt-1">Enter your credentials to access your dashboard.</p>
    </div>

    <form action="/login" method="POST" class="space-y-5">
      <div>
        <label class="block text-sm font-semibold text-slate-700 mb-1.5">Email or Login ID</label>
        <input type="text" name="identifier" required placeholder="you@company.com or AC-JADO-2026-0001"
          class="w-full rounded-xl border border-slate-200 bg-slate-50 px-4 py-3 text-sm focus:bg-white focus:border-brand-400 focus:ring-4 focus:ring-brand-100 outline-none transition" />
      </div>
      <div>
        <div class="flex items-center justify-between mb-1.5">
          <label class="block text-sm font-semibold text-slate-700">Password</label>
          <a href="/forgot" class="text-xs font-semibold text-brand-600 hover:underline">Forgot password?</a>
        </div>
        <input type="password" name="password" required placeholder="••••••••"
          class="w-full rounded-xl border border-slate-200 bg-slate-50 px-4 py-3 text-sm focus:bg-white focus:border-brand-400 focus:ring-4 focus:ring-brand-100 outline-none transition" />
      </div>
      <button class="w-full rounded-xl bg-brand-600 text-white py-3 font-semibold hover:bg-brand-700 active:scale-[.99] transition shadow-soft">
        Sign in
      </button>
    </form>

    <p class="text-sm text-center mt-6 text-slate-500">
      Don't have an account?
      <a href="/signup" class="text-brand-600 font-semibold hover:underline">Create one</a>
    </p>
  </div>
</div>

<%- include('partials/footer') %>

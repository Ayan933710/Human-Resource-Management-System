<%- include('../partials/header') %>

<%
  // Two sections shown inside every salary card.
  const earningFields = [
    ['base_salary',        'Basic salary'],
    ['house_rent',         'House rent'],
    ['allowances',         'Allowances'],
    ['standard_allowance', 'Standard allowance'],
    ['fixed_allowance',    'Fixed allowance'],
    ['performance_bonus',  'Performance bonus'],
  ];
  const deductionFields = [
    ['pf_contribution', 'PF contribution'],
    ['tax_deduction',   'Tax deduction'],
  ];
  const money = v => '₹' + Number(v || 0).toLocaleString();
%>

<div class="flex flex-wrap items-center justify-between gap-4 mb-6">
  <div>
    <h1 class="text-2xl font-extrabold text-slate-900">Salary</h1>
    <p class="text-sm text-slate-500 mt-1">
      <% if (canEdit) { %>Payroll for <%= currentUser.company %> · <%= monthLabel %>.<% } else { %>Your salary breakdown · <%= monthLabel %>.<% } %>
    </p>
  </div>
  <span class="rounded-full bg-brand-50 text-brand-700 px-3 py-1 text-sm font-semibold">
    <% if (canEdit) { %><%= rows.length %> employees<% } else { %>Read only<% } %>
  </span>
</div>

<div class="rounded-xl bg-slate-50 border border-slate-200 px-4 py-3 text-xs text-slate-500 mb-5">
  Click an employee card to expand their <span class="font-semibold text-slate-700">Earnings</span> and
  <span class="font-semibold text-slate-700">Deductions</span>. <span class="font-semibold text-slate-700">Net pay</span> = total earnings − total deductions.
  <% if (canEdit) { %> Only admins can edit these amounts.<% } else { %> Amounts are set by your admin.<% } %>
</div>

<% if (!rows.length) { %>
  <div class="bg-white rounded-2xl border border-slate-100 shadow-soft p-10 text-center text-slate-400">No salary records to show.</div>
<% } %>

<div class="grid md:grid-cols-2 gap-5">
  <% rows.forEach(r => { %>
    <details class="group bg-white rounded-2xl border border-slate-100 shadow-soft overflow-hidden">
      <!-- Card face -->
      <summary class="cursor-pointer list-none select-none p-5 flex items-center gap-4">
        <span class="grid place-items-center h-12 w-12 rounded-2xl bg-gradient-to-br from-brand-500 to-brand-700 text-white text-lg font-extrabold uppercase shadow-soft"><%= r.name.trim().charAt(0) %></span>
        <div class="min-w-0 flex-1">
          <div class="font-bold text-slate-900 truncate"><%= r.name %></div>
          <div class="text-xs text-slate-400 truncate"><%= r.login_code || r.email %></div>
        </div>
        <div class="text-right">
          <div class="text-[11px] uppercase tracking-wide text-slate-400 font-semibold">Net pay</div>
          <div class="font-extrabold text-slate-900"><%= money(r.net) %></div>
        </div>
        <svg class="h-5 w-5 text-slate-400 transition-transform group-open:rotate-180" fill="none" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" d="m19.5 8.25-7.5 7.5-7.5-7.5"/></svg>
      </summary>

      <!-- Expanded breakdown -->
      <div class="border-t border-slate-100 p-5">
        <% if (canEdit) { %><form action="/salary/<%= r.id %>" method="POST" class="space-y-6"><% } else { %><div class="space-y-6"><% } %>

          <!-- Section 1: Earnings -->
          <div>
            <div class="flex items-center justify-between mb-3">
              <h3 class="text-sm font-bold text-emerald-700 uppercase tracking-wide">Earnings</h3>
              <span class="text-sm font-bold text-emerald-700"><%= money(r.earnings) %></span>
            </div>
            <div class="grid sm:grid-cols-2 gap-4">
              <% earningFields.forEach(([key, label]) => { %>
                <div>
                  <label class="block text-xs font-semibold text-slate-500 mb-1"><%= label %></label>
                  <% if (canEdit) { %>
                    <div class="flex items-center rounded-lg border border-slate-200 bg-slate-50 focus-within:bg-white focus-within:border-brand-400 focus-within:ring-4 focus-within:ring-brand-100 transition">
                      <span class="pl-3 text-slate-400 text-sm">₹</span>
                      <input type="number" name="<%= key %>" min="0" step="1" value="<%= Number(r[key] || 0) %>"
                        class="w-full bg-transparent px-2 py-2 text-sm outline-none" />
                    </div>
                  <% } else { %>
                    <div class="rounded-lg border border-slate-100 bg-slate-50 px-3 py-2 text-sm font-semibold text-slate-800"><%= money(r[key]) %></div>
                  <% } %>
                </div>
              <% }) %>
            </div>
          </div>

          <!-- Section 2: Deductions -->
          <div>
            <div class="flex items-center justify-between mb-3">
              <h3 class="text-sm font-bold text-red-600 uppercase tracking-wide">Deductions</h3>
              <span class="text-sm font-bold text-red-600">− <%= money(r.deductions) %></span>
            </div>
            <div class="grid sm:grid-cols-2 gap-4">
              <% deductionFields.forEach(([key, label]) => { %>
                <div>
                  <label class="block text-xs font-semibold text-slate-500 mb-1"><%= label %></label>
                  <% if (canEdit) { %>
                    <div class="flex items-center rounded-lg border border-slate-200 bg-slate-50 focus-within:bg-white focus-within:border-brand-400 focus-within:ring-4 focus-within:ring-brand-100 transition">
                      <span class="pl-3 text-slate-400 text-sm">₹</span>
                      <input type="number" name="<%= key %>" min="0" step="1" value="<%= Number(r[key] || 0) %>"
                        class="w-full bg-transparent px-2 py-2 text-sm outline-none" />
                    </div>
                  <% } else { %>
                    <div class="rounded-lg border border-slate-100 bg-slate-50 px-3 py-2 text-sm font-semibold text-slate-800"><%= money(r[key]) %></div>
                  <% } %>
                </div>
              <% }) %>
            </div>
          </div>

          <!-- Net + actions -->
          <div class="flex items-center justify-between pt-4 border-t border-slate-100">
            <div>
              <div class="text-[11px] uppercase tracking-wide text-slate-400 font-semibold">Net payable</div>
              <div class="text-lg font-extrabold text-slate-900"><%= money(r.net) %></div>
            </div>
            <% if (canEdit) { %>
              <button class="rounded-xl bg-brand-600 text-white px-5 py-2.5 text-sm font-semibold hover:bg-brand-700 active:scale-[.99] transition shadow-soft">Save changes</button>
            <% } %>
          </div>

        <% if (canEdit) { %></form><% } else { %></div><% } %>
      </div>
    </details>
  <% }) %>
</div>

<%- include('../partials/footer') %>

<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>HRMS · People Platform</title>
  <script src="https://cdn.tailwindcss.com"></script>
  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
  <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700;800&display=swap" rel="stylesheet" />
  <script>
    tailwind.config = {
      theme: {
        extend: {
          fontFamily: { sans: ['Inter', 'ui-sans-serif', 'system-ui', 'sans-serif'] },
          colors: {
            brand: {
              50:'#eef2ff',100:'#e0e7ff',200:'#c7d2fe',300:'#a5b4fc',400:'#818cf8',
              500:'#6366f1',600:'#4f46e5',700:'#4338ca',800:'#3730a3',900:'#312e81'
            }
          },
          boxShadow: { soft: '0 10px 30px -12px rgba(79,70,229,0.25)' }
        }
      }
    }
  </script>
  <link rel="stylesheet" href="/style.css" />
</head>
<body class="min-h-screen bg-slate-50 text-slate-800 font-sans antialiased">

  <!-- Top navigation -->
  <nav class="sticky top-0 z-40 bg-white/80 backdrop-blur border-b border-slate-200">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 h-16 flex items-center justify-between">
      <a href="/" class="flex items-center gap-2.5 group">
        <span class="grid place-items-center h-9 w-9 rounded-xl bg-gradient-to-br from-brand-500 to-brand-700 text-white font-extrabold shadow-soft">H</span>
        <span class="font-extrabold text-lg tracking-tight text-slate-900">HRMS</span>
      </a>

      <%
        // Build the feature links once, based on role — reused by the desktop
        // bar and the mobile hamburger dropdown so they never drift apart.
        let navLinks = [];
        if (currentUser) {
          navLinks.push({ href: '/profile', label: 'Profile' });
          if (currentUser.role === 'admin') {
            navLinks.push({ href: '/employees',     label: 'Employees' });
            navLinks.push({ href: '/attendance',    label: 'Attendance' });
            navLinks.push({ href: '/leaves',        label: 'Approvals' });
            navLinks.push({ href: '/salary',        label: 'Salary' });
            navLinks.push({ href: '/employees/new', label: '+ Add Employee', cta: true });
          } else {
            // Employees now also get a (read-only) Salary tab. No "Apply Leave" for admins.
            navLinks.push({ href: '/salary',    label: 'Salary' });
            navLinks.push({ href: '/leaves/new', label: 'Apply Leave' });
          }
        }
      %>

      <!-- Desktop menu (md and up) -->
      <div class="hidden md:flex items-center gap-1 text-sm">
        <% if (currentUser) { %>
          <% navLinks.forEach(l => { %>
            <a href="<%= l.href %>" class="px-3 py-2 rounded-lg transition <%= l.cta ? 'text-brand-700 bg-brand-50 hover:bg-brand-100 font-semibold' : 'text-slate-600 hover:text-brand-700 hover:bg-brand-50 font-medium' %>"><%= l.label %></a>
          <% }) %>

          <div class="mx-2 h-6 w-px bg-slate-200"></div>

          <div class="flex items-center gap-2 pl-1">
            <span class="grid place-items-center h-8 w-8 rounded-full bg-brand-100 text-brand-700 text-xs font-bold uppercase">
              <%= currentUser.name.trim().charAt(0) %>
            </span>
            <div class="leading-tight">
              <div class="text-slate-800 font-semibold text-[13px]"><%= currentUser.name %></div>
              <div class="text-[11px] text-slate-400 capitalize"><%= currentUser.role %><% if (currentUser.company) { %> · <%= currentUser.company %><% } %></div>
            </div>
          </div>
          <a href="/logout" class="ml-1 px-3 py-2 rounded-lg text-slate-500 hover:text-red-600 hover:bg-red-50 transition font-medium">Logout</a>
        <% } else { %>
          <a href="/login" class="px-3 py-2 rounded-lg text-slate-600 hover:text-brand-700 hover:bg-brand-50 transition font-medium">Login</a>
          <a href="/signup" class="px-4 py-2 rounded-lg bg-brand-600 text-white hover:bg-brand-700 transition font-semibold shadow-soft">Get Started</a>
        <% } %>
      </div>

      <!-- Mobile hamburger button (below md) -->
      <button id="menuBtn" type="button" aria-label="Toggle menu" aria-expanded="false"
        class="md:hidden inline-grid place-items-center h-10 w-10 rounded-lg text-slate-600 hover:bg-brand-50 hover:text-brand-700 transition">
        <svg id="menuIconOpen" class="h-6 w-6" fill="none" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" d="M3.75 6.75h16.5M3.75 12h16.5m-16.5 5.25h16.5"/></svg>
        <svg id="menuIconClose" class="h-6 w-6 hidden" fill="none" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" d="M6 18 18 6M6 6l12 12"/></svg>
      </button>
    </div>

    <!-- Mobile dropdown menu (below md) -->
    <div id="mobileMenu" class="hidden md:hidden border-t border-slate-200 bg-white px-4 sm:px-6 py-3 space-y-1">
      <% if (currentUser) { %>
        <div class="flex items-center gap-3 px-2 py-2 mb-1">
          <span class="grid place-items-center h-9 w-9 rounded-full bg-brand-100 text-brand-700 text-sm font-bold uppercase"><%= currentUser.name.trim().charAt(0) %></span>
          <div class="leading-tight">
            <div class="text-slate-800 font-semibold text-sm"><%= currentUser.name %></div>
            <div class="text-[11px] text-slate-400 capitalize"><%= currentUser.role %><% if (currentUser.company) { %> · <%= currentUser.company %><% } %></div>
          </div>
        </div>
        <% navLinks.forEach(l => { %>
          <a href="<%= l.href %>" class="block px-3 py-2.5 rounded-lg transition <%= l.cta ? 'text-brand-700 bg-brand-50 font-semibold' : 'text-slate-700 hover:text-brand-700 hover:bg-brand-50 font-medium' %>"><%= l.label %></a>
        <% }) %>
        <a href="/logout" class="block px-3 py-2.5 rounded-lg text-red-600 hover:bg-red-50 font-medium transition">Logout</a>
      <% } else { %>
        <a href="/login" class="block px-3 py-2.5 rounded-lg text-slate-700 hover:text-brand-700 hover:bg-brand-50 font-medium transition">Login</a>
        <a href="/signup" class="block px-3 py-2.5 rounded-lg bg-brand-600 text-white text-center font-semibold transition">Get Started</a>
      <% } %>
    </div>
  </nav>

  <script>
    // Change 6: on mobile, all feature options collapse into this hamburger dropdown.
    (function () {
      var btn   = document.getElementById('menuBtn');
      var menu  = document.getElementById('mobileMenu');
      var open  = document.getElementById('menuIconOpen');
      var close = document.getElementById('menuIconClose');
      if (!btn || !menu) return;
      btn.addEventListener('click', function () {
        var isHidden = menu.classList.toggle('hidden'); // true => now hidden
        btn.setAttribute('aria-expanded', String(!isHidden));
        if (open)  open.classList.toggle('hidden', !isHidden);
        if (close) close.classList.toggle('hidden', isHidden);
      });
    })();
  </script>

  <main class="max-w-7xl mx-auto px-4 sm:px-6 py-8">
    <% if (typeof flash !== 'undefined' && flash) { %>
      <div class="mb-5 flex items-start gap-3 rounded-xl bg-emerald-50 border border-emerald-200 text-emerald-800 px-4 py-3 text-sm shadow-sm">
        <svg class="h-5 w-5 flex-none text-emerald-500" fill="none" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" d="m4.5 12.75 6 6 9-13.5"/></svg>
        <span><%= flash %></span>
      </div>
    <% } %>
    <% if (typeof error !== 'undefined' && error) { %>
      <div class="mb-5 flex items-start gap-3 rounded-xl bg-red-50 border border-red-200 text-red-800 px-4 py-3 text-sm shadow-sm">
        <svg class="h-5 w-5 flex-none text-red-500" fill="none" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" d="M12 9v3.75m9-.75a9 9 0 1 1-18 0 9 9 0 0 1 18 0Zm-9 3.75h.008v.008H12v-.008Z"/></svg>
        <span><%= error %></span>
      </div>
    <% } %>

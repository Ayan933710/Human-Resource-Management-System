<!-- Reusable password strength meter. Requires an <input> with id="pw" nearby.
     Pass the input id via `locals.pwId` (defaults to "pw"). -->
<% var pwId = (typeof pwId !== 'undefined' && pwId) ? pwId : 'pw'; %>
<div class="mt-2" data-pw-for="<%= pwId %>">
  <div class="h-1.5 w-full rounded-full bg-slate-200 overflow-hidden">
    <div class="pw-bar h-full w-0 rounded-full transition-all duration-300 bg-red-500"></div>
  </div>
  <p class="pw-hint mt-1.5 text-xs text-slate-400">
    Use 8+ characters with letters, numbers and a symbol.
  </p>
</div>
<script>
  (function () {
    var wrap = document.querySelector('[data-pw-for="<%= pwId %>"]');
    if (!wrap) return;
    var input = document.getElementById('<%= pwId %>');
    if (!input) return;
    var bar  = wrap.querySelector('.pw-bar');
    var hint = wrap.querySelector('.pw-hint');
    var colors = ['bg-red-500', 'bg-amber-500', 'bg-yellow-500', 'bg-emerald-500'];
    var labels = ['Weak', 'Fair', 'Good', 'Strong'];
    input.addEventListener('input', function () {
      var v = input.value, score = 0;
      if (v.length >= 8) score++;
      if (/[A-Za-z]/.test(v)) score++;
      if (/[0-9]/.test(v)) score++;
      if (/[^A-Za-z0-9]/.test(v)) score++;
      var pct = [0, 25, 50, 75, 100][score];
      bar.style.width = pct + '%';
      colors.forEach(function (c) { bar.classList.remove(c); });
      var idx = Math.max(0, score - 1);
      bar.classList.add(colors[idx]);
      hint.textContent = v ? (labels[idx] + ' — need letters, numbers & a symbol, 8+ chars')
                           : 'Use 8+ characters with letters, numbers and a symbol.';
    });
  })();
</script>
